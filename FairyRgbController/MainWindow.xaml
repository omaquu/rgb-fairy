<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller"
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#12122A" Padding="16,10">
            <TextBlock FontSize="20" FontWeight="Bold">🧚 Fairy RGB Controller</TextBlock>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Devices -->
            <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="8" Padding="10" MinWidth="200">
                <StackPanel>
                    <TextBlock FontSize="13" Foreground="#8888AA" Margin="0,0,0,8">📡 FAIRY DEVICES</TextBlock>
                    <Button x:Name="ScanButton" Content="🔄 Scan" Click="ScanButton_Click" Height="36" Background="#0F3460" BorderThickness="0" Margin="0,0,0,8"/>
                    <ListBox x:Name="DevicesListBox" Background="#12122A" Foreground="White" Height="200"
                             DisplayMemberPath="Name" SelectionChanged="DevicesListBox_SelectionChanged"/>
                    <Button x:Name="ConnectButton" Content="🔗 Connect" Click="ConnectButton_Click" Height="36" Margin="0,8,0,0"
                            Background="#4CAF50" BorderThickness="0" IsEnabled="False"/>
                    <Button x:Name="DisconnectButton" Content="⏹ Disconnect" Click="DisconnectButton_Click" Height="36" Margin="0,4,0,0"
                            Background="#3A1A2E" BorderThickness="0" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Right: Status -->
            <Border Grid.Column="1" Background="#1A1A2E" CornerRadius="8" Padding="10" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="StatusLabel" Text="Waiting..." FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ActionFeedback" Text="Press Scan to start" FontSize="12" Foreground="#8888AA"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom -->
        <Border Grid.Row="2" Background="#12122A" Padding="10">
            <Button x:Name="PowerButton" Content="🔛 TURN ON" Click="PowerButton_Click"
                    Width="130" Height="34" Background="#2A4A2E" BorderThickness="0" IsEnabled="False"/>
        </Border>
    </Grid>
</Window>