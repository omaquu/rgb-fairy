<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FairyRgbController.Converters"
        Title="Fairy RGB Controller"
        Height="720" Width="960"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        FontFamily="Segoe UI"
        TextElement.Foreground="#E0E0E0">

    <Window.Resources>
        <!-- Color palette — fairy theme: deep night + magic accent -->
        <Color x:Key="BgDark">#0D0D1A</Color>
        <Color x:Key="BgPanel">#1A1A2E</Color>
        <Color x:Key="BgCard">#16213E</Color>
        <Color x:Key="Accent">#0F3460</Color>
        <Color x:Key="AccentGlow">#1A5276</Color>
        <Color x:Key="Highlight">#E94560</Color>
        <Color x:Key="FairyGold">#F5C518</Color>
        <Color x:Key="TextMuted">#8888AA</Color>
        <Color x:Key="TextLight">#E0E0E0</Color>
        <Color x:Key="Success">#4CAF50</Color>
        <Color x:Key="Danger">#E94560</Color>

        <!-- Converters -->
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>
        <converters:BoolToTextConverter x:Key="BoolToText"/>
        <converters:HsvToColorConverter x:Key="HsvToColor"/>
        <converters:RssiToColorConverter x:Key="RssiToColor"/>

        <!-- Styles -->
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#2A2A4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style x:Key="ColorSlider" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                    <Run Text="🧚" FontSize="26"/> <Run Text="Fairy RGB Controller" Foreground="#E0E0E0"/>
                </TextBlock>
                <Border x:Name="StatusBadge" Grid.Column="2" Background="#2A2A4E" CornerRadius="16" Padding="14,6" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="🔴 Disconnected" FontSize="12" Foreground="#8888AA"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL — DEVICES ===== -->
            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="8,12,4,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource HeaderText}" Text="📡 DEVICES"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ScanButton" Grid.Column="0"
                                Style="{StaticResource ActionButton}"
                                Background="#0F3460"
                                Content="🔄 Scan for Devices"
                                Click="ScanButton_Click"
                                Height="40"/>
                        <Button x:Name="DisconnectButton" Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                Background="#3A1A2E"
                                Content="⏹"
                                Width="40" Height="40" Margin="8,0,0,0"
                                Click="DisconnectButton_Click"
                                IsEnabled="False"
                                ToolTip="Disconnect"/>
                    </Grid>

                    <ListBox x:Name="DevicesListBox"
                             Grid.Row="2"
                             Background="#12122A"
                             BorderBrush="#2A2A4E"
                             BorderThickness="1"
                             Foreground="#E0E0E0"
                             SelectionChanged="DevicesListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                    BorderThickness="0" Margin="{TemplateBinding Margin}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#2A2A4E"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#0F3460"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PairingIcon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="2" Background="#2A2A4E" CornerRadius="10" Padding="6,2"
                                            Visibility="{Binding IsPaired, Converter={StaticResource BoolToOpacity}}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="paired" FontSize="10" Foreground="#8888AA"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:Name="ConnectButton" Grid.Row="3"
                            Style="{StaticResource ActionButton}"
                            Background="#4CAF50"
                            Content="🔗 Connect"
                            Click="ConnectButton_Click"
                            Height="40"
                            Margin="0,10,0,0"
                            IsEnabled="False"/>
                </Grid>
            </Border>

            <!-- ===== RIGHT PANEL — CONTROLS ===== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" BorderThickness="0" Margin="4,8,8,4">
                <StackPanel>
                    <!-- COLOR SECTION -->
                    <Border Style="{StaticResource PanelCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource HeaderText}" Text="🎨 COLOR"/>

                            <!-- Color Preview -->
                            <Border Grid.Row="1" CornerRadius="12" Height="80" Margin="0,0,0,16"
                                    BorderBrush="#2A2A4E" BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush x:Name="ColorPreviewBrush" Color="#E94560"/>
                                </Border.Background>
                                <Border CornerRadius="12" Background="#0D0D1A" Opacity="0.3" Margin="2">
                                    <TextBlock Text="●" FontSize="40" Foreground="#FFFFFF" Opacity="0.15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>

                            <!-- Hue Slider -->
                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="🌀 Hue" FontSize="12" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Slider x:Name="HueSlider" Grid.Row="0" Grid.Column="1"
                                        Style="{StaticResource ColorSlider}"
                                        ValueChanged="ColorSlider_ValueChanged"
                                        Value="0" Maximum="360"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ElementName=HueSlider, Path=Value, StringFormat={}{0:F0}°}"
                                           FontSize="12" Foreground="#8888AA" TextAlignment="Center"/>
                            </Grid>

                            <!-- Saturation Slider -->
                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🌈 Sat" FontSize="12" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Slider x:Name="SatSlider" Grid.Column="1"
                                        Style="{StaticResource ColorSlider}"
                                        ValueChanged="ColorSlider_ValueChanged"
                                        Value="1000" Maximum="1000"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=SatSlider, Path=Value, StringFormat={}{0:F0}}"
                                           FontSize="12" Foreground="#8888AA" TextAlignment="Center"/>
                            </Grid>

                            <!-- Brightness Slider -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="☀️ Bright" FontSize="12" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Slider x:Name="BrightSlider" Grid.Column="1"
                                        Style="{StaticResource ColorSlider}"
                                        ValueChanged="ColorSlider_ValueChanged"
                                        Value="500" Maximum="1000"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=BrightSlider, Path=Value, StringFormat={}{0:F0}}"
                                           FontSize="12" Foreground="#8888AA" TextAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- PRESET COLORS -->
                    <Border Style="{StaticResource PanelCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="🎭 PRESET COLORS"/>
                            <WrapPanel Margin="0,4,0,8">
                                <Button Style="{StaticResource PresetButton}" Background="#E94560" Content="❤️" Click="PresetColor_Click" Tag="0,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#FF6B35" Content="🧡" Click="PresetColor_Click" Tag="20,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#F5C518" Content="💛" Click="PresetColor_Click" Tag="50,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#4CAF50" Content="💚" Click="PresetColor_Click" Tag="120,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#2196F3" Content="💙" Click="PresetColor_Click" Tag="200,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#9C27B0" Content="💜" Click="PresetColor_Click" Tag="270,1000,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#FF69B4" Content="💗" Click="PresetColor_Click" Tag="330,800,500"/>
                                <Button Style="{StaticResource PresetButton}" Background="#FFFFFF" Content="⬜" Click="PresetColor_Click" Tag="0,0,1000"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- EFFECTS -->
                    <Border Style="{StaticResource PanelCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="✨ EFFECTS"/>
                            <WrapPanel>
                                <Button Style="{StaticResource ActionButton}" Background="#0F3460" Content="🌈 Rainbow" Margin="4" Click="EffectButton_Click" Tag="1"/>
                                <Button Style="{StaticResource ActionButton}" Background="#0F3460" Content="⚡ Strobe" Margin="4" Click="EffectButton_Click" Tag="2"/>
                                <Button Style="{StaticResource ActionButton}" Background="#0F3460" Content="🌊 Fade" Margin="4" Click="EffectButton_Click" Tag="3"/>
                                <Button Style="{StaticResource ActionButton}" Background="#0F3460" Content="🔄 Smooth" Margin="4" Click="EffectButton_Click" Tag="4"/>
                                <Button Style="{StaticResource ActionButton}" Background="#0F3460" Content="💫 Flash" Margin="4" Click="EffectButton_Click" Tag="5"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,8,0,0">
                                <Button Style="{StaticResource ActionButton}" Background="#2A1A4E" Content="🌅 Autumn" Margin="4" Click="EffectButton_Click" Tag="38"/>
                                <Button Style="{StaticResource ActionButton}" Background="#2A1A4E" Content="🌸 Soft" Margin="4" Click="EffectButton_Click" Tag="39"/>
                                <Button Style="{StaticResource ActionButton}" Background="#2A1A4E" Content="🎨 Gradient" Margin="4" Click="EffectButton_Click" Tag="40"/>
                                <Button Style="{StaticResource ActionButton}" Background="#2A1A4E" Content="✨ Twinkle" Margin="4" Click="EffectButton_Click" Tag="42"/>
                            </WrapPanel>

                            <!-- Speed slider for effects -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⏱ Speed" FontSize="12" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Slider x:Name="SpeedSlider" Grid.Column="1"
                                        Style="{StaticResource ColorSlider}"
                                        Value="500" Maximum="1000"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=SpeedSlider, Path=Value, StringFormat={}{0:F0}}"
                                           FontSize="12" Foreground="#8888AA" TextAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Border Grid.Row="2" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Power Toggle -->
                <Button x:Name="PowerButton" Grid.Column="0"
                        Style="{StaticResource ActionButton}"
                        Background="#2A4A2E"
                        Content="🔛 TURN ON"
                        Click="PowerButton_Click"
                        Width="120" Height="36"/>

                <!-- Action feedback -->
                <TextBlock x:Name="ActionFeedback" Grid.Column="1" Text="Ready"
                           FontSize="12" Foreground="#8888AA"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>

                <!-- Set Color button -->
                <Button x:Name="SetColorButton" Grid.Column="2"
                        Style="{StaticResource ActionButton}"
                        Background="#E94560"
                        Content="🎨 Send Color"
                        Click="SetColorButton_Click"
                        Width="130" Height="36"
                        IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>