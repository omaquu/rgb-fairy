<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller"
        Height="680" Width="900"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        FontFamily="Segoe UI"
        Foreground="#E0E0E0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="20" FontWeight="Bold" VerticalAlignment="Center">🧚 Fairy RGB Controller</TextBlock>
                <Border x:Name="StatusBadge" Grid.Column="2" Background="#2A2A4E" CornerRadius="12" Padding="12,4" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="#8888AA">🔴 Disconnected</TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Devices -->
            <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,8">📡 DEVICES</TextBlock>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ScanButton" Grid.Column="0" Content="🔄 Scan for BLE" Click="ScanButton_Click"
                                Height="36" Background="#0F3460" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="DisconnectButton" Grid.Column="1" Content="⏹" Click="DisconnectButton_Click"
                                Width="36" Height="36" Margin="6,0,0,0" Background="#3A1A2E" Foreground="White"
                                BorderThickness="0" IsEnabled="False" Cursor="Hand"/>
                    </Grid>

                    <ListBox x:Name="DevicesListBox" Grid.Row="2" DisplayMemberPath="Name"
                             Background="#12122A" BorderBrush="#2A2A4E" Foreground="#E0E0E0"
                             SelectionChanged="DevicesListBox_SelectionChanged"/>

                    <TextBlock x:Name="DeviceCountText" Grid.Row="3" FontSize="11" Foreground="#666688" Margin="0,4,0,4" Text="No devices found"/>

                    <Button x:Name="ConnectButton" Grid.Row="4" Content="🔗 Connect" Click="ConnectButton_Click"
                            Height="36" Margin="0,4,0,0" Background="#4CAF50" Foreground="White"
                            BorderThickness="0" IsEnabled="False" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- RIGHT: Controls -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" BorderThickness="0" Margin="4">
                <StackPanel>

                    <!-- COLOR -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,8">🎨 COLOR</TextBlock>
                            <Border x:Name="ColorPreview" CornerRadius="8" Height="60" Margin="0,0,0,12"
                                    BorderBrush="#2A2A4E" BorderThickness="1" Background="#E94560"/>
                            <Slider x:Name="HueSlider" ValueChanged="ColorSlider_ValueChanged"
                                    Value="0" Maximum="360" Height="28"/>
                            <TextBlock FontSize="11" Foreground="#8888AA" Margin="0,0,0,4">🌀 Hue</TextBlock>
                            <Slider x:Name="SatSlider" ValueChanged="ColorSlider_ValueChanged"
                                    Value="1000" Maximum="1000" Height="28"/>
                            <TextBlock FontSize="11" Foreground="#8888AA" Margin="0,0,0,4">🌈 Saturation</TextBlock>
                            <Slider x:Name="BrightSlider" ValueChanged="ColorSlider_ValueChanged"
                                    Value="500" Maximum="1000" Height="28"/>
                            <TextBlock FontSize="11" Foreground="#8888AA" Margin="0,0,0,4">☀️ Brightness</TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- PRESET COLORS -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,6">🎭 PRESET COLORS</TextBlock>
                            <WrapPanel>
                                <Button Content="🔴" Click="PresetColor_Click" Tag="0,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#E94560" Cursor="Hand"/>
                                <Button Content="🟠" Click="PresetColor_Click" Tag="20,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#FF6B35" Cursor="Hand"/>
                                <Button Content="🟡" Click="PresetColor_Click" Tag="50,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#F5C518" Cursor="Hand"/>
                                <Button Content="🟢" Click="PresetColor_Click" Tag="120,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#4CAF50" Cursor="Hand"/>
                                <Button Content="🔵" Click="PresetColor_Click" Tag="200,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#2196F3" Cursor="Hand"/>
                                <Button Content="🟣" Click="PresetColor_Click" Tag="270,1000,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#9C27B0" Cursor="Hand"/>
                                <Button Content="💖" Click="PresetColor_Click" Tag="330,800,800" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#FF69B4" Cursor="Hand"/>
                                <Button Content="⬜" Click="PresetColor_Click" Tag="0,0,1000" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#666666" Cursor="Hand"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- EFFECTS -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,6">✨ EFFECTS</TextBlock>
                            <WrapPanel>
                                <Button Content="🌈" Click="EffectButton_Click" Tag="1" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand" ToolTip="Rainbow"/>
                                <Button Content="⚡" Click="EffectButton_Click" Tag="2" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand" ToolTip="Strobe"/>
                                <Button Content="🌊" Click="EffectButton_Click" Tag="3" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand" ToolTip="Fade"/>
                                <Button Content="🔄" Click="EffectButton_Click" Tag="4" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand" ToolTip="Smooth"/>
                                <Button Content="💫" Click="EffectButton_Click" Tag="5" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand" ToolTip="Flash"/>
                                <Button Content="🌅" Click="EffectButton_Click" Tag="38" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand" ToolTip="Autumn"/>
                                <Button Content="🌸" Click="EffectButton_Click" Tag="39" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand" ToolTip="Soft"/>
                                <Button Content="🎨" Click="EffectButton_Click" Tag="40" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand" ToolTip="Gradient"/>
                                <Button Content="✨" Click="EffectButton_Click" Tag="42" Width="44" Height="44" Margin="3" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand" ToolTip="Twinkle"/>
                            </WrapPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,8,0">⏱ Speed</TextBlock>
                                <Slider x:Name="SpeedSlider" Grid.Column="1" Value="500" Maximum="1000" Height="28"/>
                                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8888AA" TextAlignment="Center"
                                           Text="{Binding ElementName=SpeedSlider, Path=Value}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Border Grid.Row="2" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PowerButton" Grid.Column="0"
                        Content="🔛 TURN ON" Click="PowerButton_Click"
                        Width="120" Height="32" BorderThickness="0" Background="#2A4A2E" Foreground="White" Cursor="Hand"/>

                <TextBlock x:Name="ActionFeedback" Grid.Column="1" Text="Ready" FontSize="11" Foreground="#8888AA"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <Button x:Name="SetColorButton" Grid.Column="2"
                        Content="🎨 Send Color" Click="SetColorButton_Click"
                        Width="120" Height="32" BorderThickness="0" Background="#E94560" Foreground="White"
                        IsEnabled="False" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>