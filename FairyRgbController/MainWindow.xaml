<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        Foreground="White">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock FontSize="24" FontWeight="Bold" Margin="0,0,0,20">🧚 Fairy RGB Controller</TextBlock>
            <Button x:Name="ScanButton" Content="🔍 Scan for Devices" Click="ScanButton_Click" Height="36" Width="200" Margin="0,0,0,10"/>
            <TextBlock x:Name="StatusLabel" Text="Disconnected" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>