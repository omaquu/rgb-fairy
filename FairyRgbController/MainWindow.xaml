<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller"
        Height="650" Width="880"
        MinHeight="480" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        FontFamily="Segoe UI"
        Foreground="#E0E0E0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="20" FontWeight="Bold" VerticalAlignment="Center">🧚 Fairy RGB Controller</TextBlock>
                <Border x:Name="StatusBadge" Grid.Column="2" Background="#2A2A4E" CornerRadius="12" Padding="12,4" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="#8888AA">🔴 Disconnected</TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Devices -->
            <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,8">📡 DEVICES</TextBlock>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ScanButton" Grid.Column="0" Content="🔄 Scan" Click="ScanButton_Click"
                                Height="36" Background="#0F3460" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="DisconnectButton" Grid.Column="1" Content="⏹" Click="DisconnectButton_Click"
                                Width="36" Height="36" Margin="6,0,0,0" Background="#3A1A2E" Foreground="White"
                                BorderThickness="0" IsEnabled="False" Cursor="Hand"/>
                    </Grid>

                    <ListBox x:Name="DevicesListBox" Grid.Row="2" DisplayMemberPath="Name"
                             Background="#12122A" BorderBrush="#2A2A4E" Foreground="#E0E0E0"
                             SelectionChanged="DevicesListBox_SelectionChanged"/>

                    <Button x:Name="ConnectButton" Grid.Row="3" Content="🔗 Connect" Click="ConnectButton_Click"
                            Height="36" Margin="0,8,0,0" Background="#4CAF50" Foreground="White"
                            BorderThickness="0" IsEnabled="False" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- RIGHT: Controls -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" BorderThickness="0" Margin="4">
                <StackPanel>

                    <!-- COLOR -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,8">🎨 COLOR</TextBlock>

                            <!-- Preview -->
                            <Border x:Name="ColorPreview" Grid.Row="1" CornerRadius="8" Height="60" Margin="0,0,0,12"
                                    BorderBrush="#2A2A4E" BorderThickness="1" Background="#E94560"/>

                            <!-- Hue -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#8888AA" VerticalAlignment="Center">Hue</TextBlock>
                                <Slider x:Name="HueSlider" Grid.Column="1" ValueChanged="ColorSlider_ValueChanged" Value="0" Maximum="360" Minimum="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8888AA" TextAlignment="Center"
                                           Text="{Binding ElementName=HueSlider, Path=Value, StringFormat={}{0:F0}°}"/>
                            </Grid>

                            <!-- Saturation -->
                            <Grid Grid.Row="3" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#8888AA" VerticalAlignment="Center">Sat</TextBlock>
                                <Slider x:Name="SatSlider" Grid.Column="1" ValueChanged="ColorSlider_ValueChanged" Value="1000" Maximum="1000" Minimum="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8888AA" TextAlignment="Center"
                                           Text="{Binding ElementName=SatSlider, Path=Value}"/>
                            </Grid>

                            <!-- Brightness -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#8888AA" VerticalAlignment="Center">Bright</TextBlock>
                                <Slider x:Name="BrightSlider" Grid.Column="1" ValueChanged="ColorSlider_ValueChanged" Value="500" Maximum="1000" Minimum="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8888AA" TextAlignment="Center"
                                           Text="{Binding ElementName=BrightSlider, Path=Value}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- PRESETS -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,6">🎭 PRESETS</TextBlock>
                            <WrapPanel>
                                <Button Content="❤️" Click="PresetColor_Click" Tag="0,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#E94560" Cursor="Hand"/>
                                <Button Content="🧡" Click="PresetColor_Click" Tag="20,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#FF6B35" Cursor="Hand"/>
                                <Button Content="💛" Click="PresetColor_Click" Tag="50,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#F5C518" Cursor="Hand"/>
                                <Button Content="💚" Click="PresetColor_Click" Tag="120,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#4CAF50" Cursor="Hand"/>
                                <Button Content="💙" Click="PresetColor_Click" Tag="200,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#2196F3" Cursor="Hand"/>
                                <Button Content="💜" Click="PresetColor_Click" Tag="270,1000,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#9C27B0" Cursor="Hand"/>
                                <Button Content="💗" Click="PresetColor_Click" Tag="330,800,500" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#FF69B4" Cursor="Hand"/>
                                <Button Content="⬜" Click="PresetColor_Click" Tag="0,0,1000" Width="44" Height="44" Margin="2" BorderThickness="0" Background="#666666" Cursor="Hand"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- EFFECTS -->
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="#2A2A4E" BorderThickness="1" Margin="4" Padding="12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8888AA" Margin="0,0,0,6">✨ EFFECTS</TextBlock>
                            <WrapPanel>
                                <Button Content="🌈 Rainbow" Click="EffectButton_Click" Tag="1" Height="32" Margin="2" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand"/>
                                <Button Content="⚡ Strobe" Click="EffectButton_Click" Tag="2" Height="32" Margin="2" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand"/>
                                <Button Content="🌊 Fade" Click="EffectButton_Click" Tag="3" Height="32" Margin="2" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand"/>
                                <Button Content="🔄 Smooth" Click="EffectButton_Click" Tag="4" Height="32" Margin="2" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand"/>
                                <Button Content="💫 Flash" Click="EffectButton_Click" Tag="5" Height="32" Margin="2" BorderThickness="0" Background="#0F3460" Foreground="White" Cursor="Hand"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,6,0,0">
                                <Button Content="🌅 Autumn" Click="EffectButton_Click" Tag="38" Height="32" Margin="2" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand"/>
                                <Button Content="🌸 Soft" Click="EffectButton_Click" Tag="39" Height="32" Margin="2" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand"/>
                                <Button Content="🎨 Gradient" Click="EffectButton_Click" Tag="40" Height="32" Margin="2" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand"/>
                                <Button Content="✨ Twinkle" Click="EffectButton_Click" Tag="42" Height="32" Margin="2" BorderThickness="0" Background="#2A1A4E" Foreground="White" Cursor="Hand"/>
                            </WrapPanel>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#8888AA" VerticalAlignment="Center">Speed</TextBlock>
                                <Slider x:Name="SpeedSlider" Grid.Column="1" Value="500" Maximum="1000" Minimum="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" Foreground="#8888AA" TextAlignment="Center"
                                           Text="{Binding ElementName=SpeedSlider, Path=Value}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="2" Background="#12122A" BorderBrush="#2A2A4E" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PowerButton" Grid.Column="0"
                        Content="🔛 TURN ON" Click="PowerButton_Click"
                        Width="120" Height="32" BorderThickness="0" Background="#2A4A2E" Foreground="White" Cursor="Hand"/>

                <TextBlock x:Name="ActionFeedback" Grid.Column="1" Text="Ready" FontSize="11" Foreground="#8888AA"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <Button x:Name="SetColorButton" Grid.Column="2"
                        Content="🎨 Send Color" Click="SetColorButton_Click"
                        Width="120" Height="32" BorderThickness="0" Background="#E94560" Foreground="White"
                        IsEnabled="False" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>