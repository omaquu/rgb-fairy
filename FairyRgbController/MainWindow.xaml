<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Button x:Name="ScanButton" Content="Scan for Devices" Click="ScanButton_Click" Margin="10" Width="120" HorizontalAlignment="Left"/>
            <ListBox x:Name="DevicesListBox" DisplayMemberPath="Name" SelectionChanged="DevicesListBox_SelectionChanged" Margin="10,50,10,10" Height="300"/>
            <Button x:Name="ConnectButton" Content="Connect" Click="ConnectButton_Click" Margin="10" Width="120" HorizontalAlignment="Left" IsEnabled="False"/>
            <StackPanel Orientation="Horizontal" Margin="10,50,10,10">
                <Button x:Name="SetColorButton" Content="Set Color" Click="SetColorButton_Click" Margin="0,0,10,0" IsEnabled="False"/>
                <Button x:Name="SetEffectButton" Content="Set Effect" Click="SetEffectButton_Click" Margin="0,0,10,0" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>