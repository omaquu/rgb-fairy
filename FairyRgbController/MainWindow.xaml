<Window x:Class="FairyRgbController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fairy RGB Controller"
        Height="750" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        Foreground="White">

    <Window.Resources>
        <!-- Modern card style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#161625"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Primary accent button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- Preset effect button -->
        <Style x:Key="EffectButton" TargetType="Button">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D2D5A"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="border" Property="Background" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Slider style -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" Background="#2D2D5A" CornerRadius="3" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="20" Height="20" Fill="#6366F1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🧚 Fairy RGB" FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="ConnectionStatus" Text="Ei yhdistetty" FontSize="12" Foreground="#888"/>
                </StackPanel>
                <Button x:Name="ConnectButton" Grid.Column="1" Content="Yhdistä"
                        Style="{StaticResource PrimaryButton}" Click="ConnectButton_Click"/>
            </Grid>

            <!-- Device Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="LAITE"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DeviceName" Text="Valitse laite..." VerticalAlignment="Center"/>
                        <Button x:Name="ScanButton" Grid.Column="1" Content="🔍" Padding="12,8"
                                Style="{StaticResource SecondaryButton}" Click="ScanButton_Click"/>
                    </Grid>
                    <ListBox x:Name="DevicesListBox" Background="Transparent" BorderThickness="0"
                             MaxHeight="150" Margin="0,8,0,0" SelectionChanged="DevicesListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Padding="8,4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Brightness Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <Grid>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="KIRKKAUS"/>
                        <TextBlock x:Name="BrightnessValue" Text="100%" HorizontalAlignment="Right" Foreground="#6366F1"/>
                    </Grid>
                    <Slider x:Name="BrightnessSlider" Style="{StaticResource ModernSlider}"
                            Value="100" ValueChanged="BrightnessSlider_ValueChanged"/>
                </StackPanel>
            </Border>

            <!-- Quick Colors Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="VÄRIT"/>
                    <WrapPanel>
                        <Button Style="{StaticResource EffectButton}" Background="#FF0000" Width="40" Height="40" Click="QuickColor_Click" Tag="FF0000"/>
                        <Button Style="{StaticResource EffectButton}" Background="#00FF00" Width="40" Height="40" Click="QuickColor_Click" Tag="00FF00"/>
                        <Button Style="{StaticResource EffectButton}" Background="#0000FF" Width="40" Height="40" Click="QuickColor_Click" Tag="0000FF"/>
                        <Button Style="{StaticResource EffectButton}" Background="#FFFF00" Width="40" Height="40" Click="QuickColor_Click" Tag="FFFF00"/>
                        <Button Style="{StaticResource EffectButton}" Background="#FF00FF" Width="40" Height="40" Click="QuickColor_Click" Tag="FF00FF"/>
                        <Button Style="{StaticResource EffectButton}" Background="#00FFFF" Width="40" Height="40" Click="QuickColor_Click" Tag="00FFFF"/>
                        <Button Style="{StaticResource EffectButton}" Background="#FFFFFF" Width="40" Height="40" Click="QuickColor_Click" Tag="FFFFFF"/>
                        <Button Style="{StaticResource EffectButton}" Background="#FF8800" Width="40" Height="40" Click="QuickColor_Click" Tag="FF8800"/>
                    </WrapPanel>
                    <TextBlock Text="Huom: F15C tukee vain preset-värejä" FontSize="10" Foreground="#666" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Effects Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <Grid>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="EFFEKTIT"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ManageEffectsButton" Content="⚙️" Padding="8,4"
                                    Style="{StaticResource SecondaryButton}" Click="ManageEffectsButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Effect Folders -->
                    <Expander x:Name="FoldersExpander" Header="📁 Kansiot" IsExpanded="True" Foreground="White" Margin="0,8,0,0">
                        <ListBox x:Name="FoldersListBox" Background="Transparent" BorderThickness="0"
                                 SelectionChanged="FoldersListBox_SelectionChanged" Margin="0,4,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Padding="4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>

                    <!-- Effects Grid -->
                    <WrapPanel x:Name="EffectsWrapPanel" Margin="0,8,0,0"/>

                    <!-- All Effects Button -->
                    <Button x:Name="ShowAllEffectsButton" Content="Näytä kaikki efektit"
                            Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"
                            Click="ShowAllEffectsButton_Click"/>
                </StackPanel>
            </Border>

            <!-- DIY Pixel Card -->
            <Border Style="{StaticResource CardBorder}">
                <Button x:Name="PixelEditorButton" Content="🎨 Pikselipiirto"
                        Style="{StaticResource PrimaryButton}" Click="OpenPixelEditor_Click"
                        IsEnabled="False"/>
            </Border>

            <!-- Power Card -->
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PowerButton" Content="💡 ON" Style="{StaticResource PrimaryButton}"
                            Click="PowerButton_Click" Margin="0,0,6,0"/>
                    <Button x:Name="OffButton" Grid.Column="1" Content="⭕ OFF"
                            Style="{StaticResource SecondaryButton}" Click="OffButton_Click" Margin="6,0,0,0"/>
                </Grid>
            </Border>

            <!-- Spacer -->
            <Border Height="20"/>

        </StackPanel>
    </ScrollViewer>
</Window>