<Window x:Class="FairyRgbController.PixelEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎨 Pikseli-Editor - RGB Fairy"
        Height="700" Width="900"
        Background="#1A1A1A"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6C5CE7"/>
        <SolidColorBrush x:Key="OnBrush" Color="#00B894"/>
        <SolidColorBrush x:Key="OffBrush" Color="#636E72"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B2BEC3"/>
        
        <Style x:Key="GridCell" TargetType="Border">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🎨 Pikseli-Editor" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="GridSizeLabel" Text=" (8×32 = 256 pikseliä)" 
                       FontSize="14" Foreground="{StaticResource TextMutedBrush}" 
                       VerticalAlignment="Bottom" Margin="0,0,0,4"/>
        </StackPanel>
        
        <!-- Grid Size Selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Koko:" Foreground="{StaticResource TextMutedBrush}" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="GridSizeCombo" Width="150" SelectedIndex="0" SelectionChanged="GridSizeCombo_SelectionChanged">
                <ComboBoxItem Content="8 × 32 (F15C Verho)"/>
                <ComboBoxItem Content="15 × 20 (Joulukalenteri)"/>
                <ComboBoxItem Content="17 × 17 (Sydän)"/>
                <ComboBoxItem Content="20 × 15 (Ruusu)"/>
                <ComboBoxItem Content="Oma..."/>
            </ComboBox>
            
            <TextBlock Text="Työkalu:" Foreground="{StaticResource TextMutedBrush}" 
                       VerticalAlignment="Center" Margin="30,0,10,0"/>
            <RadioButton x:Name="DrawTool" Content="✏️ Piirrä" IsChecked="True" 
                         Foreground="{StaticResource TextBrush}" GroupName="Tool" Margin="0,0,15,0"/>
            <RadioButton x:Name="EraseTool" Content="🧹 Pyyhi" 
                         Foreground="{StaticResource TextBrush}" GroupName="Tool" Margin="0,0,15,0"/>
            <RadioButton x:Name="FillTool" Content="🪣 Täytä" 
                         Foreground="{StaticResource TextBrush}" GroupName="Tool"/>
        </StackPanel>
        
        <!-- Pixel Grid Canvas -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="8" 
                Padding="15" Margin="0,0,0,15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="PixelCanvas" Background="#1A1A1A" 
                        ClipToBounds="True" MouseLeftButtonDown="PixelCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="PixelCanvas_MouseLeftButtonUp"
                        MouseMove="PixelCanvas_MouseMove"/>
            </ScrollViewer>
        </Border>
        
        <!-- Color Palette -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="8" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Väri:" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                <WrapPanel>
                    <!-- Preset Colors -->
                    <Button Content="⚫" Tag="#000000" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#000000" 
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"/>
                    <Button Content="⚪" Tag="#FFFFFF" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#FFFFFF"/>
                    <Button Content="🔴" Tag="#FF0000" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#FF0000"/>
                    <Button Content="🟠" Tag="#FF8800" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#FF8800"/>
                    <Button Content="🟡" Tag="#FFFF00" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#FFFF00"/>
                    <Button Content="🟢" Tag="#00FF00" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#00FF00"/>
                    <Button Content="🔵" Tag="#0088FF" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#0088FF"/>
                    <Button Content="🟣" Tag="#8800FF" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#8800FF"/>
                    <Button Content="🔴" Tag="#FF0088" Click="ColorButton_Click" 
                            Width="40" Height="40" Margin="2" Background="#FF0088"/>
                    <!-- Custom Color Picker -->
                    <Button Content="🎨" Tag="custom" Click="CustomColor_Click" 
                            Width="40" Height="40" Margin="2" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"/>
                    <!-- Current Color Preview -->
                    <Border x:Name="CurrentColorPreview" Width="60" Height="40" Margin="15,0,0,0"
                            CornerRadius="4" Background="#FF0000" 
                            BorderBrush="{StaticResource TextMutedBrush}" BorderThickness="1"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        
        <!-- Animation Controls -->
        <Border Grid.Row="4" Background="{StaticResource CardBrush}" CornerRadius="8" 
                Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="PlayButton" Content="▶ Toista" Click="PlayButton_Click"
                            Width="80" Height="35" Margin="0,0,10,0"
                            Background="{StaticResource OnBrush}" Foreground="White" 
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="StopButton" Content="⏹ Stop" Click="StopButton_Click"
                            Width="80" Height="35" Margin="0,0,10,0"
                            Background="{StaticResource OffBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                    <CheckBox x:Name="LoopCheckBox" Content="🔁 Toista" IsChecked="True"
                              Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Nopeus:" Foreground="{StaticResource TextMutedBrush}" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="SpeedSlider" Width="200" Minimum="50" Maximum="1000" 
                            Value="200" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SpeedLabel" Text="200ms" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="10,0,0,0" Width="50"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="💾 Tallenna" Click="SaveButton_Click"
                            Width="90" Height="35" Margin="0,0,10,0"
                            Background="{StaticResource CardBrush}" Foreground="White"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"/>
                    <Button Content="📂 Lataa" Click="LoadButton_Click"
                            Width="90" Height="35" Margin="0,0,10,0"
                            Background="{StaticResource CardBrush}" Foreground="White"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"/>
                    <Button Content="📤 Lähetä" Click="SendButton_Click"
                            Width="90" Height="35" Background="{StaticResource AccentBrush}"
                            Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Status Bar -->
        <TextBlock x:Name="StatusLabel" Grid.Row="5" Text="Valmis" 
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
    </Grid>
</Window>